  status    JobStatus
  message   String?
  metadata  Json?
  duration  Int?
  ranAt     DateTime  @default(now()) @map("ran_at")

  @@index([jobName])
  @@index([ranAt(sort: Desc)])
  @@map("scheduled_job_logs")
