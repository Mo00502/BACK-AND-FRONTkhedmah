// ─── Level 61: Dispute + User suspension + Service unique ────────────────────

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeResolution {
  REFUND
  RELEASE
  SPLIT
  DISMISSED
}

model Dispute {
  id          String            @id @default(uuid())
  requestId   String            @map("request_id")
  reporterId  String            @map("reporter_id")
  againstId   String            @map("against_id")
  reason      String
  details     String?
  evidence    String[]          // file URLs
  status      DisputeStatus     @default(OPEN)
  resolution  DisputeResolution?
  resolutionNotes String?       @map("resolution_notes")
  resolvedBy  String?           @map("resolved_by")
  resolvedAt  DateTime?         @map("resolved_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  request  ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Restrict)
  reporter User           @relation("DisputesReported", fields: [reporterId], references: [id])
  against  User           @relation("DisputesAgainst",  fields: [againstId],  references: [id])

  @@index([requestId])
  @@index([status])
  @@index([reporterId])
  @@index([againstId])
  @@map("disputes")
}

// ─── Level 61: ProviderAvailability (schedule management) ────────────────────

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model ProviderSchedule {
  id         String    @id @default(uuid())
  providerId String    @map("provider_id")
  dayOfWeek  DayOfWeek @map("day_of_week")
  startTime  String    @map("start_time")  // "08:00"
  endTime    String    @map("end_time")    // "18:00"
  isWorking  Boolean   @default(true) @map("is_working")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, dayOfWeek])
  @@map("provider_schedules")
}

model ProviderVacation {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_vacations")
}

// ─── Level 61: Favourite listings ────────────────────────────────────────────

model Favourite {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refType      String   @map("ref_type")  // "PROVIDER" | "EQUIPMENT" | "TENDER"
  refId        String   @map("ref_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, refType, refId])
  @@index([userId])
  @@map("favourites")
}

// ─── Level 84: SupportTicket + SupportMessage ────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  subject          String
  description      String
  category         String
  priority         TicketPriority @default(MEDIUM)
  status           TicketStatus   @default(OPEN)
  assigneeId       String?        @map("assignee_id")
  relatedRequestId String?        @map("related_request_id")
  attachments      String[]
  resolvedAt       DateTime?      @map("resolved_at")
  closedAt         DateTime?      @map("closed_at")
  lastReplyAt      DateTime?      @map("last_reply_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  user     User             @relation("TicketsOwned",    fields: [userId],     references: [id])
  assignee User?            @relation("TicketsAssigned", fields: [assigneeId], references: [id])
  messages SupportMessage[]

  @@index([userId])
  @@index([status, priority])
  // SLA metrics: OPEN tickets sorted by createdAt for oldest-first queue
  @@index([status, createdAt(sort: Asc)])
  // Assignee workload view
  @@index([assigneeId, status])
  @@map("support_tickets")
}

model SupportMessage {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  senderId  String   @map("sender_id")
  content   String
  isStaff   Boolean  @default(false) @map("is_staff")
  createdAt DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@map("support_messages")
}

// ─── Level 74: PortfolioItem + Certification ─────────────────────────────────

model PortfolioItem {
  id          String   @id @default(uuid())
  providerId  String   @map("provider_id")
  title       String
  description String?
  imageUrls   String[] @map("image_urls")
  serviceId   String?  @map("service_id")
  createdAt   DateTime @default(now()) @map("created_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("portfolio_items")
}

model Certification {
  id          String    @id @default(uuid())
  providerId  String    @map("provider_id")
  name        String
  issuer      String
  issuedAt    DateTime  @map("issued_at")
  expiresAt   DateTime? @map("expires_at")
  fileUrl     String?   @map("file_url")
  verified    Boolean   @default(false)
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("certifications")
}

// ─── Level 72: PromoCode + PromoRedemption ───────────────────────────────────

enum PromoType {
  PERCENT
  FIXED
}

model PromoCode {
  id                String      @id @default(uuid())
  code              String      @unique
  type              PromoType
  value             Decimal     @db.Decimal(10, 2)
  minOrderAmount    Decimal     @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  maxDiscountAmount Decimal?    @map("max_discount_amount") @db.Decimal(10, 2)
  usageLimit        Int?        @map("usage_limit")
  perUserLimit      Int         @default(1) @map("per_user_limit")
  usedCount         Int         @default(0) @map("used_count")
  newUsersOnly      Boolean     @default(false) @map("new_users_only")
  serviceIds        String[]    @map("service_ids")
  description       String?
  active            Boolean     @default(true)
  expiresAt         DateTime?   @map("expires_at")
  createdAt         DateTime    @default(now()) @map("created_at")

  redemptions PromoRedemption[]

  @@index([code])
  @@map("promo_codes")
}

model PromoRedemption {
  id             String   @id @default(uuid())
  promoId        String   @map("promo_id")
  userId         String   @map("user_id")
  requestId      String?  @map("request_id")
  discountAmount Decimal  @map("discount_amount") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  promo   PromoCode @relation(fields: [promoId], references: [id])
  user    User      @relation(fields: [userId], references: [id])

  @@index([promoId, userId])
  // User redemption history
  @@index([userId, createdAt(sort: Desc)])
  @@map("promo_redemptions")
}

// ── Webhook event log (deduplication) ────────────────────────────────────────

model WebhookEvent {
  id          String   @id @default(uuid())
  provider    String   // e.g. "moyasar"
  eventId     String   @map("event_id") // provider's unique event ID
  eventType   String   @map("event_type") // e.g. "payment_paid"
  processedAt DateTime @default(now()) @map("processed_at")
  payload     Json?

  @@unique([provider, eventId])
  @@index([provider, processedAt])
  @@map("webhook_events")
}

// ── Consultations ──────────────────────────────────────────────────────────────

enum ConsultationStatus {
  PENDING    // Awaiting provider response
  ACCEPTED   // Provider accepted, session scheduled
  IN_SESSION // Session currently ongoing
  COMPLETED  // Session finished
  CANCELLED  // Cancelled by customer before session
  REJECTED   // Provider declined
}

enum ConsultationMode {
  CHAT
  VOICE
  VIDEO
}

model Consultation {
  id              String             @id @default(uuid())
  customerId      String             @map("customer_id")
  providerId      String?            @map("provider_id")
  serviceId       String             @map("service_id")
  status          ConsultationStatus @default(PENDING)
  mode            ConsultationMode   @default(CHAT)
  topic           String
  description     String?            @db.Text
  durationMinutes Int?               @map("duration_minutes")
  scheduledAt     DateTime?          @map("scheduled_at")
  startedAt       DateTime?          @map("started_at")
  completedAt     DateTime?          @map("completed_at")
  pricePerHour    Decimal?           @db.Decimal(10, 2) @map("price_per_hour")
  totalAmount     Decimal?           @db.Decimal(10, 2) @map("total_amount")
  notes           String?            @db.Text
  rating          Int?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  customer  User     @relation("ConsultationsAsCustomer", fields: [customerId], references: [id])
  provider  User?    @relation("ConsultationsAsProvider", fields: [providerId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])

  @@index([customerId])
  @@index([providerId])
  @@index([status])
  // Service catalog: consultations available for a given service
  @@index([serviceId, status])
  @@index([createdAt(sort: Desc)])
  @@map("consultations")
}

model SavedAddress {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  label      String   // e.g. "المنزل", "العمل", "المكتب"
  city       String
  district   String
  street     String?
  buildingNo String?  @map("building_no")
  notes      String?
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_addresses")
}
