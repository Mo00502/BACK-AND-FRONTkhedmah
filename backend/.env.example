# ══════════════════════════════════════════════════════════════════════════════
# Khedmah API — Environment Variables
# Copy to .env and fill in all values. NEVER commit .env to source control.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://khedmah:secret@localhost:5432/khedmah_db?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (generate with: openssl rand -hex 64) ────────────────────────────────
JWT_SECRET=CHANGE_ME_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_different_64_chars
JWT_REFRESH_EXPIRES_IN=30d

# ── Email Auth Token Settings ─────────────────────────────────────────────────
# Base URL used to build verification and reset links in emails
APP_BASE_URL=http://localhost:3000
# How long email verification links are valid (hours)
EMAIL_VERIFY_TTL_HOURS=24
# How long password reset links are valid (minutes)
RESET_TOKEN_TTL_MINUTES=60

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ── Scheduler ────────────────────────────────────────────────────────────────
ESCROW_AUTO_RELEASE_HOURS=48
MATERIALS_ADJUSTMENT_EXPIRY_HOURS=24

# ── Moyasar (payment gateway) ────────────────────────────────────────────────
MOYASAR_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOYASAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
MOYASAR_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase Admin (push notifications) ──────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=

# ── SMS — Unifonic ────────────────────────────────────────────────────────────
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=Khedmah

# ── Storage (S3 / R2 / MinIO) ────────────────────────────────────────────────
S3_ENDPOINT=https://s3.me-central-1.amazonaws.com
S3_REGION=me-central-1
S3_BUCKET=khedmah-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_MAX_FILE_SIZE_MB=20
S3_SIGNED_URL_EXPIRY=3600

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxx
SMTP_FROM=noreply@khedmah.sa
ADMIN_EMAIL=admin@khedmah.sa
REPORT_RECIPIENTS=admin@khedmah.sa

# ── Platform Business Rules ────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=15
TENDER_COMMISSION_RATE=0.02
EQUIPMENT_FEE_RATE=0.10

# ── AI (Anthropic Claude) ──────────────────────────────────────────────────────
# Optional — AI endpoints return rule-based fallbacks when not set.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SLACK_WEBHOOK_URL=
